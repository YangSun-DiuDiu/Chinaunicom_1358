<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.RoomInfoMapper">

    <resultMap type="RoomInfo" id="RoomInfoResult">
        <id     property="roomId"        column="room_id"          />
        <result property="roomCode"      column="room_code"        />
        <result property="apartmentId"   column="apartment_id"     />
        <result property="building"      column="building"         />
        <result property="floor"         column="floor"            />
        <result property="unitType"      column="unit_type"        />
        <result property="area"          column="area"             />
        <result property="rentStart"     column="rent_start"       />
        <result property="rentEnd"       column="rent_end"         />
        <result property="tenantCount"   column="tenant_count"     />
        <result property="doorType"      column="door_type"        />
        <result property="deviceStatus"  column="device_status"    />
        <result property="status"        column="status"           />
        <result property="deptId"        column="dept_id"          />
        <result property="createBy"      column="create_by"        />
        <result property="createTime"    column="create_time"      />
        <result property="updateBy"      column="update_by"        />
        <result property="updateTime"    column="update_time"      />
        <result property="remark"        column="remark"           />
    </resultMap>

    <sql id="selectRoomInfoVo">
        select room_id, room_code, apartment_id, building, floor,
               unit_type, area, rent_start, rent_end, tenant_count,
               door_type, device_status, status, dept_id, create_by,
               create_time, update_by, update_time, remark
        from room_info
    </sql>

    <select id="selectRoomInfoList" parameterType="RoomInfo" resultMap="RoomInfoResult">
        <include refid="selectRoomInfoVo"/>
        <where>
            <if test="roomCode != null and roomCode != ''">
                AND room_code like concat('%', #{roomCode}, '%')
            </if>
            <if test="apartmentId != null">
                AND apartment_id = #{apartmentId}
            </if>
            <if test="building != null and building != ''">
                AND building like concat('%', #{building}, '%')
            </if>
            <if test="floor != null and floor != ''">
                AND floor like concat('%', #{floor}, '%')
            </if>
            <if test="unitType != null and unitType != ''">
                AND unit_type like concat('%', #{unitType}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
            <!-- 数据权限过滤 -->
            ${params.dataScope}
        </where>
    </select>

    <select id="selectRoomInfoById" parameterType="Long" resultMap="RoomInfoResult">
        <include refid="selectRoomInfoVo"/>
        where room_id = #{roomId}
    </select>

    <select id="selectRoomCardList" parameterType="RoomInfo" resultMap="RoomInfoResult">
        <include refid="selectRoomInfoVo"/>
        <where>
            <if test="apartmentId != null">
                AND apartment_id = #{apartmentId}
            </if>
            <if test="building != null and building != ''">
                AND building like concat('%', #{building}, '%')
            </if>
            <if test="floor != null and floor != ''">
                AND floor like concat('%', #{floor}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <!-- 数据权限过滤 -->
            ${params.dataScope}
        </where>
    </select>

    <insert id="insertRoomInfo" parameterType="RoomInfo" useGeneratedKeys="true" keyProperty="roomId">
        insert into room_info (
            <if test="roomCode != null and roomCode != ''">room_code,</if>
            <if test="apartmentId != null">apartment_id,</if>
            <if test="building != null and building != ''">building,</if>
            <if test="floor != null and floor != ''">floor,</if>
            <if test="unitType != null and unitType != ''">unit_type,</if>
            <if test="area != null">area,</if>
            <if test="rentStart != null">rent_start,</if>
            <if test="rentEnd != null">rent_end,</if>
            <if test="tenantCount != null">tenant_count,</if>
            <if test="doorType != null and doorType != ''">door_type,</if>
            <if test="deviceStatus != null and deviceStatus != ''">device_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="roomCode != null and roomCode != ''">#{roomCode},</if>
            <if test="apartmentId != null">#{apartmentId},</if>
            <if test="building != null and building != ''">#{building},</if>
            <if test="floor != null and floor != ''">#{floor},</if>
            <if test="unitType != null and unitType != ''">#{unitType},</if>
            <if test="area != null">#{area},</if>
            <if test="rentStart != null">#{rentStart},</if>
            <if test="rentEnd != null">#{rentEnd},</if>
            <if test="tenantCount != null">#{tenantCount},</if>
            <if test="doorType != null and doorType != ''">#{doorType},</if>
            <if test="deviceStatus != null and deviceStatus != ''">#{deviceStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateRoomInfo" parameterType="RoomInfo">
        update room_info
        <set>
            <if test="roomCode != null and roomCode != ''">room_code = #{roomCode},</if>
            <if test="apartmentId != null">apartment_id = #{apartmentId},</if>
            <if test="building != null and building != ''">building = #{building},</if>
            <if test="floor != null and floor != ''">floor = #{floor},</if>
            <if test="unitType != null and unitType != ''">unit_type = #{unitType},</if>
            <if test="area != null">area = #{area},</if>
            <if test="rentStart != null">rent_start = #{rentStart},</if>
            <if test="rentEnd != null">rent_end = #{rentEnd},</if>
            <if test="tenantCount != null">tenant_count = #{tenantCount},</if>
            <if test="doorType != null and doorType != ''">door_type = #{doorType},</if>
            <if test="deviceStatus != null and deviceStatus != ''">device_status = #{deviceStatus},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where room_id = #{roomId}
    </update>

    <delete id="deleteRoomInfoById" parameterType="Long">
        delete from room_info where room_id = #{roomId}
    </delete>

    <delete id="deleteRoomInfoByIds" parameterType="Long">
        delete from room_info where room_id in
        <foreach item="roomId" collection="array" open="(" separator="," close=")">
            #{roomId}
        </foreach>
    </delete>

</mapper>
