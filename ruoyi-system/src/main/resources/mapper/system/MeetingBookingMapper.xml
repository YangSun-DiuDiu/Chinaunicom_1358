<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MeetingBookingMapper">

    <resultMap type="MeetingBooking" id="MeetingBookingResult">
        <id     property="bookingId"    column="booking_id"     />
        <result property="roomId"       column="room_id"        />
        <result property="roomName"     column="room_name"      />
        <result property="title"        column="title"          />
        <result property="hostName"     column="host_name"      />
        <result property="hostPhone"    column="host_phone"     />
        <result property="startTime"    column="start_time"     />
        <result property="endTime"      column="end_time"       />
        <result property="attendees"    column="attendees"      />
        <result property="status"       column="status"         />
        <result property="deptId"       column="dept_id"        />
        <result property="createBy"     column="create_by"      />
        <result property="createTime"   column="create_time"    />
        <result property="updateBy"     column="update_by"      />
        <result property="updateTime"   column="update_time"    />
        <result property="remark"       column="remark"         />
    </resultMap>

    <sql id="selectMeetingBookingVo">
        select b.booking_id, b.room_id, b.title, b.host_name, b.host_phone,
               b.start_time, b.end_time, b.attendees, b.status, b.dept_id,
               b.create_by, b.create_time, b.update_by, b.update_time, b.remark,
               r.room_name
        from meeting_booking b
        left join meeting_room r on b.room_id = r.room_id
    </sql>

    <select id="selectMeetingBookingList" parameterType="MeetingBooking" resultMap="MeetingBookingResult">
        <include refid="selectMeetingBookingVo"/>
        <where>
            <if test="roomId != null">
                AND b.room_id = #{roomId}
            </if>
            <if test="title != null and title != ''">
                AND b.title like concat('%', #{title}, '%')
            </if>
            <if test="hostName != null and hostName != ''">
                AND b.host_name like concat('%', #{hostName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND b.status = #{status}
            </if>
            <if test="createBy != null and createBy != ''">
                AND b.create_by = #{createBy}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(b.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(b.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
            </if>
            <!-- 数据权限过滤 -->
            ${params.dataScope}
        </where>
    </select>

    <select id="selectMeetingBookingById" parameterType="Long" resultMap="MeetingBookingResult">
        <include refid="selectMeetingBookingVo"/>
        where b.booking_id = #{bookingId}
    </select>

    <insert id="insertMeetingBooking" parameterType="MeetingBooking" useGeneratedKeys="true" keyProperty="bookingId">
        insert into meeting_booking (
            <if test="roomId != null">room_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="hostName != null and hostName != ''">host_name,</if>
            <if test="hostPhone != null and hostPhone != ''">host_phone,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="attendees != null">attendees,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="remark != null and remark != ''">remark,</if>
            create_time
        )values(
            <if test="roomId != null">#{roomId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="hostName != null and hostName != ''">#{hostName},</if>
            <if test="hostPhone != null and hostPhone != ''">#{hostPhone},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="attendees != null">#{attendees},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            sysdate()
        )
    </insert>

    <update id="updateMeetingBooking" parameterType="MeetingBooking">
        update meeting_booking
        <set>
            <if test="roomId != null">room_id = #{roomId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="hostName != null and hostName != ''">host_name = #{hostName},</if>
            <if test="hostPhone != null and hostPhone != ''">host_phone = #{hostPhone},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="attendees != null">attendees = #{attendees},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where booking_id = #{bookingId}
    </update>

    <delete id="deleteMeetingBookingById" parameterType="Long">
        delete from meeting_booking where booking_id = #{bookingId}
    </delete>

    <delete id="deleteMeetingBookingByIds" parameterType="Long">
        delete from meeting_booking where booking_id in
        <foreach item="bookingId" collection="array" open="(" separator="," close=")">
            #{bookingId}
        </foreach>
    </delete>

    <select id="countConflict" resultType="int">
        SELECT COUNT(*) FROM meeting_booking
        WHERE room_id = #{roomId} AND status IN ('PENDING','APPROVED')
        AND start_time &lt; #{endTime} AND end_time &gt; #{startTime}
        <if test="excludeBookingId != null">AND booking_id != #{excludeBookingId}</if>
    </select>

    <select id="selectTodayByRoom" parameterType="Long" resultMap="MeetingBookingResult">
        <include refid="selectMeetingBookingVo"/>
        WHERE b.room_id = #{roomId}
        AND b.status IN ('PENDING','APPROVED')
        AND DATE(b.start_time) = CURDATE()
        ORDER BY b.start_time ASC
    </select>

    <select id="selectSlots" resultMap="MeetingBookingResult">
        <include refid="selectMeetingBookingVo"/>
        WHERE b.room_id = #{roomId} AND DATE(b.start_time) = #{date}
        AND b.status IN ('PENDING','APPROVED')
        ORDER BY b.start_time
    </select>

</mapper>
